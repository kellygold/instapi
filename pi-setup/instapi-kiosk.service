[Unit]
Description=InstaPi Kiosk Browser
After=instapi.service network.target
Wants=instapi.service

[Service]
Type=simple
User=@@USER@@
Environment=DISPLAY=:0
ExecStartPre=/bin/sleep 10
ExecStart=@@HOME@@/instapi/pi-setup/kiosk.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
