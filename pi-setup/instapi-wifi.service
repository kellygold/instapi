[Unit]
Description=InstaPi WiFi Setup Check
Before=instapi.service
After=NetworkManager.service sys-subsystem-net-devices-wlan0.device
Wants=NetworkManager.service sys-subsystem-net-devices-wlan0.device

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=@@HOME@@/instapi/pi-setup/wifi-setup.sh check

[Install]
WantedBy=multi-user.target
